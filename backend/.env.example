# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (Local Development)
# For local MySQL, use these default values:
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=school_management
DB_PORT=3306

# JWT Secret (IMPORTANT: Change this in production!)
JWT_SECRET=your_super_secret_jwt_key_123_change_in_production

# Cloudinary Configuration
# Get your credentials from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# ============================================
# INSTRUCTIONS:
# ============================================
# 1. Copy this file to .env
# 2. Update the values with your actual credentials
# 3. Never commit .env file to git (it's in .gitignore)
#
# For local development:
# - DB_HOST: localhost (your local MySQL)
# - DB_USER: root (default MySQL user)
# - DB_PASSWORD: (leave empty if no password, or add your MySQL password)
# - DB_NAME: school_management
#
# For production (Render):
# - Get database credentials from your cloud provider (PlanetScale, Railway, AWS RDS)
# - Update all values with production credentials
# - Use strong passwords (20+ characters)
